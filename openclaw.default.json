{
  "env": {
    "vars": {
      "OPENCLAW_GATEWAY_TOKEN": "${OPENCLAW_GATEWAY_TOKEN}",
      "OPENCLAW_GATEWAY_CONTROL_UI_ALLOWED_ORIGINS": "${OPENCLAW_GATEWAY_CONTROL_UI_ALLOWED_ORIGINS}",
      "OPENCLAW_DEFAULT_MODEL": "${OPENCLAW_DEFAULT_MODEL:-ski-gateway-openai/gpt-5.2}",
      "OPENCLAW_STATE_DIR": "${OPENCLAW_STATE_DIR:-/data}",
      "OPENCLAW_WORKSPACE": "${OPENCLAW_WORKSPACE:-/data/workspace}",
      "SKI_GATEWAY_OPENAI_BASE_URL": "${SKI_GATEWAY_OPENAI_BASE_URL}",
      "SKI_GATEWAY_OPENAI_API_KEY": "${SKI_GATEWAY_OPENAI_API_KEY}",
      "SKI_GATEWAY_CLAUDE_BASE_URL": "${SKI_GATEWAY_CLAUDE_BASE_URL}",
      "SKI_GATEWAY_CLAUDE_API_KEY": "${SKI_GATEWAY_CLAUDE_API_KEY}"
    }
  },
  "gateway": {
    "port": 18789,
    "controlUi": {
      "enabled": true,
      "allowedOrigins": ["${OPENCLAW_GATEWAY_CONTROL_UI_ALLOWED_ORIGINS}"]
    },
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "ski-gateway-openai": {
        "baseUrl": "${SKI_GATEWAY_OPENAI_BASE_URL:-https://api.ski.example.com/openai/v1}",
        "apiKey": "${SKI_GATEWAY_OPENAI_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "ski-gateway-openai/gpt-5.2",
            "name": "GPT-5.2 (via SKI Gateway)"
          },
          {
            "id": "ski-gateway-openai/gpt-5-mini",
            "name": "GPT-5 Mini (via SKI Gateway)"
          }
        ]
      },
      "ski-gateway-claude": {
        "baseUrl": "${SKI_GATEWAY_CLAUDE_BASE_URL:-https://api.ski.example.com/anthropic/v1}",
        "apiKey": "${SKI_GATEWAY_CLAUDE_API_KEY}",
        "api": "anthropic-messages",
        "models": [
          {
            "id": "ski-gateway-claude/claude-opus-4-6",
            "name": "Claude Opus 4.6 (via SKI Gateway)"
          },
          {
            "id": "ski-gateway-claude/claude-sonnet-4-5",
            "name": "Claude Sonnet 4.5 (via SKI Gateway)"
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "${OPENCLAW_DEFAULT_MODEL:-ski-gateway-openai/gpt-5.2}",
        "fallbacks": ["ski-gateway-claude/claude-sonnet-4-5"]
      },
      "imageModel": {
        "primary": "ski-gateway-claude/claude-sonnet-4-5"
      },
      "workspace": "${OPENCLAW_WORKSPACE:-/data/workspace}"
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "identity": {
          "name": "OpenClaw"
        },
        "workspace": "${OPENCLAW_WORKSPACE:-/data/workspace}"
      }
    ]
  },
  "browser": {
    "enabled": true,
    "headless": true
  }
}
